<Window x:Class="WpfApp1.SavedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Saves" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.85*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Background="#00000000" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="36" FontFamily="Tahoma" FontWeight="Bold">Saved Readings</Label>
        <ListView Grid.Row="1" Name="SavedCards">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <WrapPanel>
                        <TextBlock Text="Date: " />
                        <TextBlock Text="{Binding dateTime}" FontWeight="Bold" />
                        <TextBlock Text=", Pulled Cards: " />
                        <TextBlock Text="{Binding cardNames}" FontWeight="Bold" />
                        <TextBlock Text=", Label: " />
                        <TextBlock Text="{Binding label}" FontWeight="Bold" />
                    </WrapPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
