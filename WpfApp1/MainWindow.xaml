<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Tarot Reader" Height="450" Width="800">


    <Grid Background="#FFC4AAF0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.45*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="1.25*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="33*"/>
            <ColumnDefinition Width="33*"/>
            <ColumnDefinition Width="67*"/>
        </Grid.ColumnDefinitions>


        <Label Background="Transparent" Grid.ColumnSpan="3" Grid.Row="0" HorizontalAlignment="Center" FontFamily="Sitka Subheading" FontSize="40" Foreground="White" Height="48" VerticalAlignment="Center">
            <Label.Effect>
                <DropShadowEffect
                  ShadowDepth="4"
                  Direction="330"
                  Color="Black"
                  Opacity="0.5"
                 BlurRadius="4"/>
            </Label.Effect>
            What does the future hold?
        </Label>

        <Button Foreground="White" Background="#FF2E5F6E" Grid.Row="1" Grid.ColumnSpan="1" Click="Button_Click" FontFamily="SimSun" FontSize="36" FontWeight="Bold" BorderThickness="0,0,0,0" Margin="16,0,16,0" >Generate</Button>
        <Button Foreground="White" Background="#FF2E5F6E" Grid.Row="2" Grid.ColumnSpan="1" FontFamily="SimSun" FontSize="36" FontWeight="Bold" BorderThickness="0,0,0,0" Margin="16,0,16,0">Save</Button>
        <Button Foreground="White" Background="#FF2E5F6E" Grid.Row="3" Grid.ColumnSpan="1" Click="Open_Saves" FontFamily="SimSun" FontSize="22" FontWeight="Bold" BorderThickness="0,0,0,0" Margin="16,0,16,0">View Previous</Button>

        <StackPanel Grid.Row="4" Grid.Column="0" ScrollViewer.VerticalScrollBarVisibility="Disabled" VerticalAlignment="Top" HorizontalAlignment="Center">
            <StackPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0"/>
                </TransformGroup>
            </StackPanel.RenderTransform>


            <Label>What cards shall you include?</Label>

            <RadioButton Name="radioMajor" IsChecked="True">Major Arcana</RadioButton>
            <RadioButton Name="radioMinor">Minor Arcana</RadioButton>
            <RadioButton Name="radioFull">Full Deck</RadioButton>
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top" ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <StackPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0"/>
                </TransformGroup>
            </StackPanel.RenderTransform>

            <Label>Number of Cards</Label>
            <RadioButton Name="radio1" IsChecked="True">1</RadioButton>
            <RadioButton Name="radio2">2</RadioButton>
            <RadioButton Name="radio3">3</RadioButton>
            <RadioButton Name="radio4">4</RadioButton>
            <RadioButton Name="radio5">5</RadioButton>
            <RadioButton Name="radio6">6</RadioButton>
            <RadioButton Name="radio7">7</RadioButton>
            <RadioButton Name="radio8">8</RadioButton>
            <RadioButton Name="radio9">9</RadioButton>
            <RadioButton Name="radio10">10</RadioButton>
        </StackPanel>




        <Image Visibility="Collapsed" Name="oneListBox" Source ="/images/Ace of Cups.png" Grid.Column="3" Grid.RowSpan="4" Grid.Row="1"/>


        <ListBox Background="Transparent" Visibility="Collapsed" Name="twoListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" Grid.Column="3" Grid.RowSpan="4" Grid.Row="1">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>


            <Image Name="Two_One" Source ="/images/Ace of Cups.png"/>
            <Image Name="Two_Two" Source ="/images/Ace of Cups.png"/>
        </ListBox>

        <ListBox Background="Transparent" Visibility="Collapsed" Name="threeListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" Grid.Column="3" Grid.RowSpan="4" Grid.Row="1">
