        </ListBox>

        <ListBox Background="Transparent" Visibility="Collapsed" Name="tenListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" Grid.Column="3" Grid.RowSpan="4" Grid.Row="1">
            <ListBox.ItemsPanel>
