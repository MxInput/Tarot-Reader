<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label>Generate</Label>
        <Label Name="teller" Margin="0,0,274,353"></Label>
        <Button Margin="10,252,700,135" Click="Button_Click">Generate</Button>
        <StackPanel Margin="263,264,367,70" RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0"/>
                </TransformGroup>
            </StackPanel.RenderTransform>
            <Label>What cards shall you include?</Label>

            <RadioButton Name="radioMajor" IsChecked="True">Major Arcana</RadioButton>
            <RadioButton Name="radioMinor">Minor Arcana</RadioButton>
            <RadioButton Name="radioFull">Full Deck</RadioButton>
        </StackPanel>

        <StackPanel Margin="124,264,567,11" RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0"/>
                </TransformGroup>
            </StackPanel.RenderTransform>

            <Label>Number of Cards</Label>

            <RadioButton Name="radio1" IsChecked="True">1</RadioButton>
            <RadioButton Name="radio2">2</RadioButton>
            <RadioButton Name="radio3">3</RadioButton>
            <RadioButton Name="radio4">4</RadioButton>
            <RadioButton Name="radio5">5</RadioButton>
            <RadioButton Name="radio6">6</RadioButton>
            <RadioButton Name="radio7">7</RadioButton>
            <RadioButton Name="radio8">8</RadioButton>
            <RadioButton Name="radio9">9</RadioButton>
            <RadioButton Name="radio10">10</RadioButton>
        </StackPanel>

        <Image  Name="oneListBox" Source ="/images/Ace of Cups.png" Margin="530,0,-2,0"/>

        
        
        <ListBox Visibility="Collapsed" Name="nineListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="494,0,0,0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid/>  
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <Image MaxWidth="200" Name="Nine_One" Source ="/images/Ace of Cups.png"/>
            <Image MaxWidth="200" Name="Nine_Two" Source ="/images/Ace of Cups.png"/>
            <Image MaxWidth="200" Name="Nine_Three" Source ="/images/Ace of Cups.png"/>

            <Image MaxWidth="200" Name="Nine_Four" Source ="/images/Ace of Cups.png"/>
            <Image MaxWidth="200" Name="Nine_Five" Source ="/images/Ace of Cups.png"/>
            <Image MaxWidth="200" Name="Nine_Six" Source ="/images/Ace of Cups.png"/>

            <Image MaxWidth="200" Name="Nine_Seven" Source ="/images/Ace of Cups.png"/>
            <Image MaxWidth="200" Name="Nine_Eight" Source ="/images/Ace of Cups.png"/>
            <Image MaxWidth="200" Name="Nine_Nine" Source ="/images/Ace of Cups.png"/>
        </ListBox>
    </Grid>
</Window>
