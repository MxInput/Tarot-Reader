<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label>Welcome</Label>
        <Label Name="teller"></Label>
        <Button Margin="27,234,487,37" Click="Button_Click">Generate</Button>
        <StackPanel Margin="350,234,306,100" RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0"/>
                </TransformGroup>
            </StackPanel.RenderTransform>

            <RadioButton Name="radioMajor" IsChecked="True">Major Arcana</RadioButton>
            <RadioButton Name="radioMinor">Minor Arcana</RadioButton>
            <RadioButton Name="radioFull">Full Deck</RadioButton>
        </StackPanel>
    </Grid>
</Window>
